# Install all dependencies
install:
    uv sync --all-groups

# Run tests
test:
    uv run --group test --with-editable . pytest

# Run tests with coverage
test-cov:
    uv run --group test --with-editable . pytest --cov=./ --cov-report=xml

# Run type checking
typing:
    uv run --group typing --group test --isolated ty check

# Run linting and formatting
lint:
    uvx prek run -a

# Run all checks
check: lint typing test
